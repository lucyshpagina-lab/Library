{
  "name": "library",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=web",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "lint": "eslint 'server/src/**/*.ts' 'web/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'server/src/**/*.ts' 'web/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'server/src/**/*.ts' 'web/src/**/*.{ts,tsx}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
