{
  "name": "autotests",
  "version": "1.0.0",
  "description": "E2E tests for Library app using Playwright with Page Object pattern",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "report": "echo '\\n  Open report: file://$(pwd)/report/index.html\\n' && python3 -m http.server 9323 -d report 2>/dev/null || open report/index.html || xdg-open report/index.html",
    "test:auth": "npx playwright test tests/auth.spec.ts",
    "test:catalog": "npx playwright test tests/catalog.spec.ts",
    "test:books": "npx playwright test tests/book-crud.spec.ts",
    "test:favorites": "npx playwright test tests/favorites.spec.ts",
    "test:interactions": "npx playwright test tests/book-interactions.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
